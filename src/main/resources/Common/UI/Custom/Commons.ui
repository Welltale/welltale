$Sounds = "Sound.ui";

@ColorBackground = #0f141a(0.94);
@ColorSurface = #1a232d(0.96);
@ColorSurfaceAlt = #222d38(0.96);
@ColorBorder = #31414f(1.00);
@ColorTextMain = #e5ebf2(1.00);
@ColorTextMuted = #94a2b2(1.00);
@ColorAccent = #d2a85d(1.00);
@ColorAccentHover = #e0ba79(1.00);
@ColorDanger = #9f4d4d(1.00);
@ColorDangerHover = #b36060(1.00);

@WelltaleColor = @ColorAccent;

@SmallLabel = (FontSize: 11, TextColor: @ColorTextMuted);
@BodyLabel = (FontSize: 13, TextColor: @ColorTextMain);
@HeadingLabel = (FontName: "Secondary", FontSize: 16, RenderUppercase: true, RenderBold: true, LetterSpacing: 1, TextColor: @ColorAccent, Alignment: Center);

@CancelButtonStyle = TextButtonStyle(
  Default: (
    Background: @ColorDanger, LabelStyle: (FontSize: 13, TextColor: @ColorTextMain, RenderBold: true, Alignment: Center, RenderUppercase: true)
  ),
  Hovered: (
    Background: @ColorDangerHover, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, Alignment: Center, RenderUppercase: true)
  ),
  Pressed: (
    Background: #7f3f3f(1.00), LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, Alignment: Center, RenderUppercase: true)
  ),
  Sounds: $Sounds.@ButtonsCancel,
);

@MainButtonStyle = TextButtonStyle(
  Default: (
    Background: @ColorAccent, LabelStyle: (FontSize: 13, TextColor: #10161c, RenderBold: true, Alignment: Center, RenderUppercase: true)
  ),
  Hovered: (
    Background: @ColorAccentHover, LabelStyle: (FontSize: 13, TextColor: #0d141b, RenderBold: true, Alignment: Center, RenderUppercase: true)
  ),
  Pressed: (
    Background: #b88f4d(1.00), LabelStyle: (FontSize: 13, TextColor: #0d141b, RenderBold: true, Alignment: Center, RenderUppercase: true)
  ),
  Sounds: $Sounds.@ButtonsMain,
);

@EnterButtonStyle = TextButtonStyle(
  Default: (
    Background: #79a96a(1.00), LabelStyle: (FontSize: 13, TextColor: #0f171d, RenderBold: true, Alignment: Center, RenderUppercase: true)
  ),
  Hovered: (
    Background: #89bb78(1.00), LabelStyle: (FontSize: 13, TextColor: #0f171d, RenderBold: true, Alignment: Center, RenderUppercase: true)
  ),
  Pressed: (
    Background: #68955b(1.00), LabelStyle: (FontSize: 13, TextColor: #0f171d, RenderBold: true, Alignment: Center, RenderUppercase: true)
  ),
  Sounds: $Sounds.@EnterWorld,
);

@ClickableSlotButtonStyle = ButtonStyle(
  Default: (
    Background: @ColorSurface
  ),
  Hovered: (
    Background: @ColorSurfaceAlt
  ),
  Pressed: (
    Background: #101820(1.00)
  ),
  Sounds: $Sounds.@ButtonsLight,
);

@HytaleContainerBackground = @ColorBackground;
@HytaleHeaderBackground = @ColorSurface;
@HytalePanelBackground = @ColorSurface;
@HytaleSectionSeparator = Group {
  Anchor: (Height: 2, Right: 0, Left: 0, Top: 8, Bottom: 8);
  Background: @ColorBorder;
};

@HytaleVerticalSeparator = Group {
  Anchor: (Width: 2, Top: 8, Bottom: 8);
  Background: @ColorBorder;
};

@SmallSpacer = Group {
  Anchor: (Width: 5, Right: 0, Left: 0, Top: 5, Bottom: 5);
};

@MediumSpacer = Group {
  Anchor: (Width: 15, Right: 0, Left: 0, Top: 15, Bottom: 15);
};

@BigSpacer = Group {
  Anchor: (Width: 30, Right: 0, Left: 0, Top: 30, Bottom: 30);
};

@WhiteSeparator = Group {
  LayoutMode: Left;
  Anchor: (Height: 1, Right: 0, Left: 0, Top: 10, Bottom: 10);
  Background: #e5ebf2(0.18);
};

@WelltaleSeparator = Group {
  LayoutMode: Left;
  Anchor: (Height: 2, Right: 0, Left: 0, Top: 10, Bottom: 10);
  Background: @WelltaleColor;
};
